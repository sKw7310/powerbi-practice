table DimCustomer
	lineageTag: 6b70f731-ebf1-417a-bef0-8bfa23583230

	measure 'Total Cost' = SUM(FactSales[CostAmount])
		lineageTag: c032c05a-cd2f-432f-89fd-67d4e8dcaa3d

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Gross Profit' = SUM(FactSales[GrossProfit])
		lineageTag: abb94242-abfa-4bcb-bb41-aba54685447e

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Gross Margin %' = DIVIDE([Gross Profit], [Total Sales], 0)
		lineageTag: d63d4c0b-d35d-4ef8-843b-1caef43b0acc

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Orders' = DISTINCTCOUNT(FactSales[SalesOrderID])
		formatString: 0
		lineageTag: 8b0cc10a-01f8-41b8-a1f8-7809a6a5d503

	measure 'Avg Order Value' = DIVIDE([Total Sales], [Total Orders], 0)
		lineageTag: 60579caf-d137-48df-8ec4-3c9fd3355f8e

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'YTD Sales' = TOTALYTD([Total Sales], DimDate[Date])
		formatString: 0
		lineageTag: 8b79c155-423a-4baa-bc72-7c47846456bd

	measure 'Sales LY' = CALCULATE([Total Sales], SAMEPERIODLASTYEAR(DimDate[Date]))
		formatString: 0
		lineageTag: eb52be7e-bc78-4804-83f3-9428b0223b3b

	measure 'Sales vs LY %' = ```
			DIVIDE([Total Sales] - [Sales LY], [Sales LY], 0)
			
			
			```
		lineageTag: 38dc5463-04e9-4ba9-9fe2-0c9bb94775a3

		annotation PBI_FormatHint = {"isGeneralNumber":true}

